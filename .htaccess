Options -MultiViews
RewriteEngine On
RewriteBase /

# 1. Handle Admin Clean URLs (Priority)
# If /admin/something is requested and /admin/something.php exists, rewrite to it.
RewriteCond %{DOCUMENT_ROOT}/admin/$1.php -f
RewriteRule ^admin/(.*)$ admin/$1.php [L]

# 2. Redirect /index.php to /
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /index\.php\ HTTP/
RewriteRule ^index\.php$ / [R=301,L]

# 3. Internally rewrite /page to /page.php for root files
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.*)$ $1.php [L]

# 4. Redirect /page.php to /page (SEO) - Exclude Admin
RewriteCond %{REQUEST_URI} !^/admin/
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([^\ ]+)\.php\ HTTP/
RewriteRule ^(.+)\.php$ /$1 [R=301,L]
